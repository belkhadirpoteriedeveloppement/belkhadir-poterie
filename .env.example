# Configuration Twilio pour WhatsApp (vendeur uniquement)
# Obtenez ces informations depuis votre console Twilio : https://console.twilio.com/

# SID du compte Twilio (obligatoire)
TWILIO_ACCOUNT_SID=votre_account_sid_ici

# Token d'authentification Twilio (obligatoire)
TWILIO_AUTH_TOKEN=votre_auth_token_ici

# Numéro WhatsApp Twilio d'envoi (optionnel, par défaut: +14155238886)
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Numéro WhatsApp du vendeur pour recevoir les notifications (optionnel, par défaut: +212675202336)
TWILIO_TO_NUMBER=whatsapp:+212675202336

# Configuration de l'environnement
NODE_ENV=development
